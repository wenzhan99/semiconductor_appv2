    {
      "id": "ct_f3_electron_drift_current_density",
      "name": "Electron drift current density",
      "equation_latex": "J_{n,\\mathrm{drift}} = q n \\mu_n \\mathcal{E}",
      "description": "Electron drift current density from carrier density and mobility.",
      "variables": [
        {
          "key": "J_n_drift",
          "name": "Electron drift current density",
          "si_unit": "A/m^2",
          "preferred_units": ["A/m^2"],
          "constraints": { "type": "finite" }
        },
        {
          "key": "n",
          "name": "Electron concentration",
          "si_unit": "m^-3",
          "preferred_units": ["m^-3", "cm^-3"],
          "constraints": { "type": "positive" }
        },
        {
          "key": "mu_n",
          "name": "Electron mobility",
          "si_unit": "m^2/(V*s)",
          "preferred_units": ["m^2/(V*s)", "cm^2/(V*s)"],
          "constraints": { "type": "positive" }
        },
        {
          "key": "E_field",
          "name": "Electric field",
          "si_unit": "V/m",
          "preferred_units": ["V/m"],
          "constraints": { "type": "finite" }
        }
      ],
      "constants_used": [
        { "key": "q", "source": "physical_constants_table", "note": "Elementary charge" }
      ],
      "solvable_for": ["J_n_drift", "n", "mu_n", "E_field"],
      "compute": {
        "J_n_drift": "q*n*mu_n*E_field",
        "n": "J_n_drift/(q*mu_n*E_field)",
        "mu_n": "J_n_drift/(q*n*E_field)",
        "E_field": "J_n_drift/(q*n*mu_n)"
      },
      "version": 2
    },
