    {
      "id": "ct_total_electron_current_density",
      "name": "Total electron current density",
      "equation_latex": "J_{n} = q n\\mu_{n}\\mathcal{E} + q D_{n}\\frac{dn}{dx}",
      "description": "Total electron current density (drift + diffusion).",
      "variables": [
        {
          "key": "J_n",
          "name": "Total electron current density",
          "si_unit": "A/m^2",
          "preferred_units": ["A/m^2"],
          "constraints": { "type": "finite" }
        },
        {
          "key": "n",
          "name": "Electron concentration",
          "si_unit": "m^-3",
          "preferred_units": ["m^-3", "cm^-3"],
          "constraints": { "type": "positive" }
        },
        {
          "key": "mu_n",
          "name": "Electron mobility",
          "si_unit": "m^2/(V*s)",
          "preferred_units": ["m^2/(V*s)", "cm^2/(V*s)"],
          "constraints": { "type": "positive" }
        },
        {
          "key": "E_field",
          "name": "Electric field",
          "si_unit": "V/m",
          "preferred_units": ["V/m"],
          "constraints": { "type": "finite" }
        },
        {
          "key": "D_n",
          "name": "Electron diffusion coefficient",
          "si_unit": "m^2/s",
          "preferred_units": ["m^2/s"],
          "constraints": { "type": "positive" }
        },
        {
          "key": "dn_dx",
          "name": "Electron concentration gradient",
          "si_unit": "m^-4",
          "preferred_units": ["m^-4"],
          "constraints": { "type": "finite" }
        }
      ],
      "constants_used": [
        { "key": "q", "source": "physical_constants_table", "note": "Elementary charge" }
      ],
      "solvable_for": ["J_n", "n", "mu_n", "E_field", "D_n", "dn_dx"],
      "compute": {
        "J_n": "q*n*mu_n*E_field + q*D_n*dn_dx",
        "n": "(J_n - q*D_n*dn_dx)/(q*mu_n*E_field)",
        "mu_n": "(J_n - q*D_n*dn_dx)/(q*n*E_field)",
        "E_field": "(J_n - q*D_n*dn_dx)/(q*n*mu_n)",
        "D_n": "(J_n - q*n*mu_n*E_field)/(q*dn_dx)",
        "dn_dx": "(J_n - q*n*mu_n*E_field)/(q*D_n)"
      },
      "notes": [
        "Converts carrier concentration from cm^-3 to m^-3 internally if needed."
      ],
      "version": 1
    },
    {
      "id": "ct_total_hole_current_density",
