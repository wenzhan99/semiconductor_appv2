    {
      "id": "ct_f5_electron_diffusion_current_density",
      "name": "Electron diffusion current density (steady-state)",
      "equation_latex": "J_{n,\\mathrm{diff}} = q D_n \\frac{dn}{dx}",
      "description": "Electron diffusion current density using carrier gradient.",
      "variables": [
        {
          "key": "J_n_diff",
