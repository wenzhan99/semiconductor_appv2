    },
    {
      "id": "ct_f9_conductivity",
      "name": "Conductivity",
      "equation_latex": "\\sigma = q(n\\mu_n + p\\mu_p)",
      "description": "Electrical conductivity from carrier densities and mobilities.",
      "variables": [
        {
          "key": "sigma",
          "name": "Conductivity",
          "si_unit": "S/m",
          "preferred_units": ["S/m"],
          "constraints": { "type": "positive" }
        },
        {
          "key": "n",
          "name": "Electron concentration",
          "si_unit": "m^-3",
          "preferred_units": ["m^-3", "cm^-3"],
          "constraints": { "type": "positive" }
        },
        {
          "key": "mu_n",
          "name": "Electron mobility",
          "si_unit": "m^2/(V*s)",
          "preferred_units": ["m^2/(V*s)", "cm^2/(V*s)"],
          "constraints": { "type": "positive" }
        },
        {
          "key": "p",
          "name": "Hole concentration",
          "si_unit": "m^-3",
          "preferred_units": ["m^-3", "cm^-3"],
          "constraints": { "type": "positive" }
        },
        {
          "key": "mu_p",
          "name": "Hole mobility",
          "si_unit": "m^2/(V*s)",
          "preferred_units": ["m^2/(V*s)", "cm^2/(V*s)"],
          "constraints": { "type": "positive" }
        }
      ],
      "constants_used": [
        { "key": "q", "source": "physical_constants_table", "note": "Elementary charge" }
      ],
      "solvable_for": ["sigma", "n", "p", "mu_n", "mu_p"],
      "compute": {
        "sigma": "q*(n*mu_n + p*mu_p)",
        "n": "(sigma/q - p*mu_p)/mu_n",
        "p": "(sigma/q - n*mu_n)/mu_p",
        "mu_n": "(sigma/q - p*mu_p)/n",
        "mu_p": "(sigma/q - n*mu_n)/p"
      },
      "version": 1
    },
    {
      "id": "ct_f10_resistivity",
      "name": "Resistivity",
      "equation_latex": "\\rho = \\frac{1}{\\sigma}",
