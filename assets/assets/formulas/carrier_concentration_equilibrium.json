    {
      "id": "doped_n_type_majority",
      "name": "Equilibrium majority carrier (n-type, compensated)",
      "equation_latex": "n_{0} = \\frac{(N_{D} - N_{A}) + \\sqrt{(N_{D} - N_{A})^{2} + 4 n_{i}^{2}}}{2}",
      "description": "",
      "variables": [
        {
          "key": "n_0",
          "name": "Equilibrium electron concentration",
          "si_unit": "m^-3",
          "preferred_units": ["m^-3", "cm^-3"],
          "constraints": { "type": "nonnegative" }
        },
        {
          "key": "N_D",
          "name": "Donor concentration",
          "si_unit": "m^-3",
          "preferred_units": ["m^-3", "cm^-3"],
          "constraints": { "type": "nonnegative" }
        },
        {
          "key": "N_A",
          "name": "Acceptor concentration",
          "si_unit": "m^-3",
          "preferred_units": ["m^-3", "cm^-3"],
          "constraints": { "type": "nonnegative" }
        },
        {
          "key": "n_i",
          "name": "Intrinsic carrier concentration",
          "si_unit": "m^-3",
          "preferred_units": ["m^-3", "cm^-3"],
          "constraints": { "type": "positive" }
        }
      ],
      "constants_used": [],
      "solvable_for": ["n_0", "n_i", "N_A", "N_D"],
      "compute": {
        "n_0": "((N_D-N_A) + sqrt((N_D-N_A)*(N_D-N_A) + 4*n_i*n_i))/2",
        "n_i": "0.5*sqrt(4*n_0*(N_A - N_D + n_0))",
        "N_A": "N_D - n_0 + (n_i*n_i)/n_0",
        "N_D": "N_A + n_0 - (n_i*n_i)/n_0"
      },
      "version": 1
    },
