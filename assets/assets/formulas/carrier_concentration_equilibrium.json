    {
      "id": "mass_action_law",
      "name": "Mass action law",
      "equation_latex": "n_i^2 = n_0 p_0",
      "description": "",
      "variables": [
        {
          "key": "n_i",
          "name": "Intrinsic carrier concentration",
          "si_unit": "m^-3",
          "preferred_units": ["m^-3", "cm^-3"],
          "constraints": { "type": "positive" }
        },
        {
          "key": "n_0",
          "name": "Equilibrium electron concentration",
          "si_unit": "m^-3",
          "preferred_units": ["m^-3", "cm^-3"],
          "constraints": { "type": "positive" }
        },
        {
          "key": "p_0",
          "name": "Equilibrium hole concentration",
          "si_unit": "m^-3",
          "preferred_units": ["m^-3", "cm^-3"],
          "constraints": { "type": "positive" }
        }
      ],
      "constants_used": [],
      "solvable_for": ["n_0", "p_0", "n_i"],
      "compute": {
