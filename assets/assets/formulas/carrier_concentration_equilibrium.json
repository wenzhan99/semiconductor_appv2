  ],
  "formulas": [
    {
      "id": "carrier_electron_concentration_n0",
      "name": "Equilibrium electron concentration",
      "equation_latex": "n_{0} = n_{i}\\,\\exp\\left(\\frac{E_{F} - E_{i}}{kT}\\right)",
      "description": "",
      "variables": [
        {
          "key": "n_0",
          "name": "Equilibrium electron concentration",
          "si_unit": "m^-3",
          "preferred_units": ["m^-3", "cm^-3"],
          "constraints": { "type": "positive" }
        },
        {
          "key": "n_i",
          "name": "Intrinsic carrier concentration",
          "si_unit": "m^-3",
          "preferred_units": ["m^-3", "cm^-3"],
          "constraints": { "type": "positive" }
        },
        {
          "key": "E_F",
          "name": "Fermi level",
          "si_unit": "J",
          "preferred_units": ["J", "eV"],
          "constraints": { "type": "finite" }
        },
        {
          "key": "E_i",
          "name": "Intrinsic energy level",
          "si_unit": "J",
          "preferred_units": ["J", "eV"],
          "constraints": { "type": "finite" }
        },
        {
          "key": "T",
          "name": "Temperature",
          "si_unit": "K",
          "preferred_units": ["K"],
          "constraints": { "type": "positive" }
        }
      ],
      "constants_used": [
        { "key": "k", "source": "physical_constants_table", "note": "Boltzmann constant" }
      ],
      "solvable_for": ["n_0", "E_F", "E_i", "T", "n_i"],
      "compute": {
        "n_0": "n_i*exp((E_F-E_i)/(k*T))",
        "E_F": "E_i + (k*T)*ln(n_0/n_i)",
        "E_i": "E_F - (k*T)*ln(n_0/n_i)",
        "T": "(E_F-E_i)/(k*ln(n_0/n_i))",
        "n_i": "n_0*exp(-(E_F-E_i)/(k*T))"
      },
      "version": 1
    },
