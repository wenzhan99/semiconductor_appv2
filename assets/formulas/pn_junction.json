          "si_unit": "F/m",
          "preferred_units": [
            "F/m"
          ],
          "constraints": {
            "type": "positive"
          }
        },
        {
          "key": "q",
          "name": "Elementary charge",
          "si_unit": "C",
          "preferred_units": [
            "C"
          ],
          "constraints": {
            "type": "positive"
          }
        },
        {
          "key": "N_A",
          "name": "Acceptor concentration",
          "si_unit": "m^-3",
          "preferred_units": [
            "m^-3",
            "cm^-3"
          ],
          "constraints": {
            "type": "positive"
          }
        },
        {
          "key": "N_D",
          "name": "Donor concentration",
          "si_unit": "m^-3",
          "preferred_units": [
            "m^-3",
            "cm^-3"
          ],
          "constraints": {
            "type": "positive"
          }
        },
        {
          "key": "V_dep",
          "name": "Depletion potential",
          "si_unit": "V",
          "preferred_units": [
            "V"
          ],
          "constraints": {
            "type": "finite"
          }
        }
      ],
      "constants_used": [
        {
          "key": "q",
          "source": "physical_constants_table",
          "note": "Elementary charge"
        }
      ],
      "solvable_for": [
        "W",
        "eps_s",
        "V_dep",
        "N_A",
        "N_D"
      ],
      "compute": {
        "W": "sqrt((2*eps_s/q)*((N_A+N_D)/(N_A*N_D))*V_dep)",
        "eps_s": "(W*W*q*(N_A*N_D))/(2*V_dep*(N_A+N_D))",
        "V_dep": "(W*W*q*(N_A*N_D))/(2*eps_s*(N_A+N_D))",
        "N_A": "1/(((W*W*q)/(2*eps_s*V_dep)) - (1/N_D))",
        "N_D": "1/(((W*W*q)/(2*eps_s*V_dep)) - (1/N_A))"
      },
      "version": 1
    },
