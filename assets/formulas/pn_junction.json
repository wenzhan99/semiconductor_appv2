  "formulas": [
    {
      "id": "pn_built_in_potential",
      "name": "Built-in potential",
      "equation_latex": "V_{bi}=\\frac{kT}{q}\\ln\\left(\\frac{N_A N_D}{n_i^{2}}\\right)",
      "description": "Built-in potential of an abrupt pn junction.",
      "variables": [
        {
          "key": "V_bi",
          "name": "Built-in potential",
          "si_unit": "V",
          "preferred_units": [
            "V"
          ],
          "constraints": {
            "type": "finite"
          }
        },
        {
          "key": "T",
          "name": "Temperature",
          "si_unit": "K",
          "preferred_units": [
            "K"
          ],
          "constraints": {
            "type": "positive"
          }
        },
        {
          "key": "N_A",
          "name": "Acceptor concentration",
          "si_unit": "m^-3",
          "preferred_units": [
            "m^-3",
            "cm^-3"
          ],
          "constraints": {
            "type": "positive"
          }
        },
        {
          "key": "N_D",
          "name": "Donor concentration",
          "si_unit": "m^-3",
          "preferred_units": [
            "m^-3",
            "cm^-3"
          ],
          "constraints": {
            "type": "positive"
          }
        },
        {
          "key": "n_i",
          "name": "Intrinsic concentration",
          "si_unit": "m^-3",
          "preferred_units": [
            "m^-3",
            "cm^-3"
          ],
          "constraints": {
            "type": "positive"
          }
        }
      ],
      "constants_used": [
        {
          "key": "k",
          "source": "physical_constants_table",
          "note": "Boltzmann constant"
        },
        {
          "key": "q",
          "source": "physical_constants_table",
          "note": "Elementary charge"
        }
      ],
      "solvable_for": [
        "V_bi",
        "T",
        "N_A",
        "N_D",
        "n_i",
        "k",
        "q"
      ],
      "compute": {
        "V_bi": "(k*T/q)*ln((N_A*N_D)/(n_i*n_i))",
        "T": "(V_bi*q)/(k*ln((N_A*N_D)/(n_i*n_i)))",
        "N_A": "(n_i*n_i*exp(V_bi*q/(k*T)))/N_D",
        "N_D": "(n_i*n_i*exp(V_bi*q/(k*T)))/N_A",
        "n_i": "sqrt((N_A*N_D)/exp(V_bi*q/(k*T)))",
        "k": "(V_bi*q)/(T*ln((N_A*N_D)/(n_i*n_i)))",
        "q": "(k*T*ln((N_A*N_D)/(n_i*n_i)))/V_bi"
      },
      "notes": [
        "If N_A/N_D/n_i entered in cm^-3, they will be converted to m^-3 internally.",
        "Autosolve any single missing variable."
      ],
      "version": 1
    },
    {
      "id": "pn_depletion_width",
      "name": "Depletion width (abrupt junction)",
      "equation_latex": "W=\\sqrt{\\frac{2\\varepsilon_s}{q}\\left(\\frac{N_A+N_D}{N_A N_D}\\right)V_{dep}}",
      "description": "Total depletion width for an abrupt pn junction.",
      "variables": [
        {
          "key": "W",
          "name": "Depletion width",
          "si_unit": "m",
          "preferred_units": [
            "m"
          ],
          "constraints": {
            "type": "positive"
          }
        },
        {
          "key": "eps_s",
